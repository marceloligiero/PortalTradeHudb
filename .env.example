# ══════════════════════════════════════════════════════
# .env.example — variáveis do docker-compose
# Copiar para .env:  copy .env.example .env  (Windows)
#                    cp .env.example .env    (Linux/Mac)
#
# PORTAS: valores por defeito altos para evitar conflitos
# com outras aplicações no servidor Windows.
# ══════════════════════════════════════════════════════

# ── MySQL ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=mudar-em-producao-root
MYSQL_DATABASE=tradehub_db
MYSQL_USER=tradehub_user
MYSQL_PASSWORD=mudar-em-producao

# ── Portas expostas no host ────────────────────────────
# Alterar se houver conflito com outras aplicações
BACKEND_PORT=8100
FRONTEND_PORT=8080
DB_PORT=3307

# ── Override dev (só no docker-compose.override.yml) ──
FRONTEND_DEV_PORT=5173

# ══════════════════════════════════════════════════════
# Grafana OSS
# ══════════════════════════════════════════════════════
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=DEFINIR_PASSWORD_FORTE
GRAFANA_DOMAIN=localhost

# ══════════════════════════════════════════════════════
# Grafana SSO — Microsoft Entra ID (Azure AD)
# ══════════════════════════════════════════════════════
# Activar SSO: definir GRAFANA_SSO_ENABLED=true e preencher as vars abaixo.
# Sem SSO (default): deixar GRAFANA_SSO_ENABLED=false — login local funciona.
#
# Setup: ver docs/GRAFANA_SSO_SETUP.md para instruções passo-a-passo.
#
# Resumo rápido:
#   1. portal.azure.com → Microsoft Entra ID → App Registrations → New
#   2. Nome: "TradeHub Grafana"
#   3. Redirect URI (Web): https://SEU_DOMINIO/grafana/login/azuread
#   4. Copiar Application ID → GRAFANA_AZURE_CLIENT_ID
#   5. Copiar Directory ID → AZURE_TENANT_ID
#   6. Certificates & secrets → New client secret → copiar Value
#   7. API Permissions → Graph → openid, email, profile, User.Read → Grant consent
#
GRAFANA_SSO_ENABLED=false
AZURE_TENANT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
GRAFANA_AZURE_CLIENT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
GRAFANA_AZURE_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
