{
  "uid": "tradehub-home",
  "title": "TradeHub — Visão Geral",
  "description": "KPIs globais da plataforma: formações, tutoria, chamados e erros internos",
  "tags": ["tradehub", "home", "overview"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "timezone": "browser",
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Utilizadores Ativos",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM users WHERE is_active = 1",
        "format": "table",
        "refId": "A"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Formações Concluídas (30d)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM enrollments WHERE completed_at >= NOW() - INTERVAL 30 DAY",
        "format": "table",
        "refId": "A"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Erros Tutoria Abertos",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM tutoria_errors WHERE status NOT IN ('RESOLVED','CANCELLED') AND is_active = 1",
        "format": "table",
        "refId": "A"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Chamados em Aberto",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 30, "color": "red" }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM chamados WHERE status IN ('ABERTO','EM_ANDAMENTO','EM_REVISAO')",
        "format": "table",
        "refId": "A"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Certificados Emitidos",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM certificates WHERE is_valid = 1",
        "format": "table",
        "refId": "A"
      }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Erros Internos Pendentes",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 15, "color": "red" }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM internal_errors WHERE status IN ('PENDENTE','AGUARDANDO_GRAVADOR') AND is_active = 1",
        "format": "table",
        "refId": "A"
      }]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Atividade da Plataforma (últimos 30 dias)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "tradehub-mysql" },
          "rawSql": "SELECT DATE(enrolled_at) AS time, COUNT(*) AS Inscrições FROM enrollments WHERE enrolled_at >= NOW() - INTERVAL 30 DAY GROUP BY DATE(enrolled_at) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": { "uid": "tradehub-mysql" },
          "rawSql": "SELECT DATE(created_at) AS time, COUNT(*) AS 'Erros Tutoria' FROM tutoria_errors WHERE created_at >= NOW() - INTERVAL 30 DAY GROUP BY DATE(created_at) ORDER BY time",
          "format": "time_series",
          "refId": "B"
        },
        {
          "datasource": { "uid": "tradehub-mysql" },
          "rawSql": "SELECT DATE(created_at) AS time, COUNT(*) AS Chamados FROM chamados WHERE created_at >= NOW() - INTERVAL 30 DAY GROUP BY DATE(created_at) ORDER BY time",
          "format": "time_series",
          "refId": "C"
        }
      ]
    },

    {
      "id": 8,
      "type": "piechart",
      "title": "Utilizadores por Papel",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT role AS metric, COUNT(*) AS value FROM users WHERE is_active = 1 GROUP BY role ORDER BY value DESC",
        "format": "table",
        "refId": "A"
      }]
    },

    {
      "id": 9,
      "type": "piechart",
      "title": "Planos de Formação por Status",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT status AS metric, COUNT(*) AS value FROM training_plans WHERE is_active = 1 GROUP BY status ORDER BY value DESC",
        "format": "table",
        "refId": "A"
      }]
    }

  ]
}
