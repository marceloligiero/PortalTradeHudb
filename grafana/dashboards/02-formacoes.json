{
  "uid": "tradehub-formacoes",
  "title": "TradeHub — Formações",
  "description": "Análise de cursos, planos de formação, progressos e desafios",
  "tags": ["tradehub", "formacoes"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10m",
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total de Cursos Ativos",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM courses WHERE is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Planos Ativos",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM training_plans WHERE is_active = 1 AND status IN ('PENDING','IN_PROGRESS')",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Taxa de Conclusão Geral",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 50, "color": "yellow" },
              { "value": 75, "color": "green" }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(SUM(completed_at IS NOT NULL) * 100.0 / COUNT(*), 1) AS value FROM enrollments",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "MPU Médio Geral",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 3, "color": "yellow" },
              { "value": 6, "color": "green" }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(AVG(mpu), 2) AS value FROM lesson_progress WHERE mpu IS NOT NULL AND mpu > 0",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Planos em Atraso",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM training_plans WHERE end_date < NOW() AND status NOT IN ('COMPLETED') AND is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Desafios Aprovados (30d)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM challenge_submissions WHERE is_approved = 1 AND created_at >= NOW() - INTERVAL 30 DAY",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Inscrições por Dia",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "legend": { "displayMode": "hidden" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 }, "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT DATE(enrolled_at) AS time, COUNT(*) AS Inscrições FROM enrollments WHERE enrolled_at >= NOW() - INTERVAL 90 DAY GROUP BY DATE(enrolled_at) ORDER BY time",
        "format": "time_series", "refId": "A"
      }]
    },

    {
      "id": 8,
      "type": "barchart",
      "title": "Top 10 Cursos por Inscrições",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "hidden" }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT c.title AS Curso, COUNT(e.id) AS Inscrições FROM enrollments e JOIN courses c ON e.course_id = c.id GROUP BY c.id, c.title ORDER BY Inscrições DESC LIMIT 10",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 9,
      "type": "piechart",
      "title": "Status das Aulas (lesson_progress)",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT status AS metric, COUNT(*) AS value FROM lesson_progress GROUP BY status ORDER BY value DESC",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 10,
      "type": "piechart",
      "title": "Status dos Desafios",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT CASE WHEN is_approved = 1 THEN 'Aprovado' WHEN is_approved = 0 THEN 'Reprovado' ELSE 'Pendente' END AS metric, COUNT(*) AS value FROM challenge_submissions GROUP BY metric",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 11,
      "type": "table",
      "title": "Progressos por Aluno (MPU médio)",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "sortBy": [{ "displayName": "MPU Médio", "desc": true }] },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT u.full_name AS Aluno, COUNT(lp.id) AS 'Aulas', ROUND(AVG(lp.mpu), 2) AS 'MPU Médio', SUM(lp.status = 'COMPLETED') AS Concluídas FROM lesson_progress lp JOIN users u ON lp.user_id = u.id WHERE lp.mpu IS NOT NULL GROUP BY u.id, u.full_name ORDER BY 'MPU Médio' DESC LIMIT 20",
        "format": "table", "refId": "A"
      }]
    }

  ]
}
