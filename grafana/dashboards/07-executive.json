{
  "uid": "tradehub-executive",
  "title": "TradeHub — Relatório Executivo",
  "description": "Vista consolidada para gestores e diretores — SLA, performance e tendências",
  "tags": ["tradehub", "executive"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30m",
  "time": { "from": "now-6M", "to": "now" },
  "timezone": "browser",
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Utilizadores Totais",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM users WHERE is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Certificados Emitidos",
      "gridPos": { "x": 3, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM certificates WHERE is_valid = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Taxa Conclusão Planos (%)",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 60, "color": "yellow" }, { "value": 80, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(SUM(status = 'COMPLETED') * 100.0 / COUNT(*), 1) AS value FROM training_plans WHERE is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "MPU Médio Plataforma",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "decimals": 2, "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(AVG(mpu), 2) AS value FROM lesson_progress WHERE mpu IS NOT NULL AND mpu > 0",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Taxa Resolução Chamados (%)",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 50, "color": "yellow" }, { "value": 75, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(SUM(status = 'CONCLUIDO') * 100.0 / COUNT(*), 1) AS value FROM chamados",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "SLA Erros Críticos (resolução < 48h)",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 80, "color": "yellow" }, { "value": 95, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(SUM(TIMESTAMPDIFF(HOUR, created_at, completed_at) <= 48) * 100.0 / COUNT(*), 1) AS value FROM chamados WHERE priority = 'CRITICA' AND status = 'CONCLUIDO' AND completed_at IS NOT NULL",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Erros Internos (Senso Atual)",
      "gridPos": { "x": 18, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 30, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(ie.id) AS value FROM internal_errors ie JOIN sensos s ON ie.senso_id = s.id WHERE s.status = 'ATIVO' AND ie.is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 8,
      "type": "stat",
      "title": "Avaliação Média Cursos (estrelas)",
      "gridPos": { "x": 21, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 3, "color": "yellow" }, { "value": 4, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(AVG(stars), 1) AS value FROM ratings WHERE rating_type = 'COURSE'",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Evolução Mensal — Formações Concluídas vs Certificados",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        {
          "datasource": { "uid": "tradehub-mysql" },
          "rawSql": "SELECT DATE_FORMAT(completed_at, '%Y-%m-01') AS time, COUNT(*) AS 'Planos Concluídos' FROM training_plans WHERE completed_at >= NOW() - INTERVAL 6 MONTH AND status = 'COMPLETED' GROUP BY DATE_FORMAT(completed_at, '%Y-%m-01') ORDER BY time",
          "format": "time_series", "refId": "A"
        },
        {
          "datasource": { "uid": "tradehub-mysql" },
          "rawSql": "SELECT DATE_FORMAT(issued_at, '%Y-%m-01') AS time, COUNT(*) AS Certificados FROM certificates WHERE issued_at >= NOW() - INTERVAL 6 MONTH AND is_valid = 1 GROUP BY DATE_FORMAT(issued_at, '%Y-%m-01') ORDER BY time",
          "format": "time_series", "refId": "B"
        }
      ]
    },

    {
      "id": 10,
      "type": "piechart",
      "title": "Mix Chamados: Bug vs Melhoria",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT type AS metric, COUNT(*) AS value FROM chamados GROUP BY type",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 11,
      "type": "table",
      "title": "Performance por Equipa (últimos 90 dias)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "sortBy": [{ "displayName": "Conclusão (%)", "desc": true }] },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT t.name AS Equipa, COUNT(DISTINCT u.id) AS Membros, COUNT(DISTINCT tp.id) AS 'Planos Totais', SUM(tp.status = 'COMPLETED') AS Concluídos, ROUND(SUM(tp.status = 'COMPLETED') * 100.0 / NULLIF(COUNT(DISTINCT tp.id), 0), 1) AS 'Conclusão (%)', ROUND(AVG(lp.mpu), 2) AS 'MPU Médio' FROM teams t JOIN users u ON u.team_id = t.id LEFT JOIN training_plans tp ON tp.student_id = u.id AND tp.created_at >= NOW() - INTERVAL 90 DAY LEFT JOIN lesson_progress lp ON lp.user_id = u.id AND lp.created_at >= NOW() - INTERVAL 90 DAY WHERE t.is_active = 1 GROUP BY t.id, t.name ORDER BY 'Conclusão (%)' DESC",
        "format": "table", "refId": "A"
      }]
    }

  ]
}
