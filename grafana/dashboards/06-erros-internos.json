{
  "uid": "tradehub-erros-internos",
  "title": "TradeHub — Erros Internos (Sensos)",
  "description": "Sensos, erros internos identificados por liberadores, pesos e planos de ação",
  "tags": ["tradehub", "erros-internos"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10m",
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Sensos Ativos",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM sensos WHERE status = 'ATIVO' AND is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total Erros Internos",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 30, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM internal_errors WHERE is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Pendentes de Avaliação",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 15, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM internal_errors WHERE status IN ('PENDENTE','AGUARDANDO_GRAVADOR') AND is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Fichas de Aprendizagem Não Lidas",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 3, "color": "yellow" }, { "value": 10, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM learning_sheets WHERE is_read = 0",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Planos de Ação Criados",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM internal_error_action_plans",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Peso Médio dos Erros",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 7, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(AVG(peso_tutor), 1) AS value FROM internal_errors WHERE peso_tutor IS NOT NULL AND is_active = 1",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Erros Internos Registados por Dia",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "legend": { "displayMode": "hidden" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 }, "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT DATE(date_occurrence) AS time, COUNT(*) AS 'Erros' FROM internal_errors WHERE date_occurrence >= DATE_SUB(CURDATE(), INTERVAL 90 DAY) AND is_active = 1 GROUP BY DATE(date_occurrence) ORDER BY time",
        "format": "time_series", "refId": "A"
      }]
    },

    {
      "id": 8,
      "type": "piechart",
      "title": "Status dos Erros",
      "gridPos": { "x": 14, "y": 4, "w": 5, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT status AS metric, COUNT(*) AS value FROM internal_errors WHERE is_active = 1 GROUP BY status ORDER BY value DESC",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 9,
      "type": "piechart",
      "title": "Classificação dos Erros",
      "gridPos": { "x": 19, "y": 4, "w": 5, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT classification AS metric, COUNT(*) AS value FROM internal_error_classifications GROUP BY classification ORDER BY value DESC",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 10,
      "type": "barchart",
      "title": "Erros por Atividade (Top 10)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "hidden" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT a.name AS Atividade, COUNT(ie.id) AS Total FROM internal_errors ie JOIN activities a ON ie.activity_id = a.id WHERE ie.is_active = 1 GROUP BY a.id, a.name ORDER BY Total DESC LIMIT 10",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 11,
      "type": "table",
      "title": "Top Gravadores por Erros",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "sortBy": [{ "displayName": "Total", "desc": true }] },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT u.full_name AS Gravador, COUNT(ie.id) AS Total, ROUND(AVG(ie.peso_tutor), 1) AS 'Peso Médio', SUM(ie.status = 'CONCLUIDO') AS Concluídos FROM internal_errors ie JOIN users u ON ie.gravador_id = u.id WHERE ie.is_active = 1 GROUP BY u.id, u.full_name ORDER BY Total DESC LIMIT 15",
        "format": "table", "refId": "A"
      }]
    }

  ]
}
