{
  "uid": "tradehub-chamados",
  "title": "TradeHub — Portal de Chamados",
  "description": "Bugs e melhorias reportadas pelos utilizadores — Kanban analytics",
  "tags": ["tradehub", "chamados"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Abertos",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 30, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM chamados WHERE status = 'ABERTO'",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Em Andamento",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM chamados WHERE status = 'EM_ANDAMENTO'",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Concluídos (30d)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM chamados WHERE status = 'CONCLUIDO' AND completed_at >= NOW() - INTERVAL 30 DAY",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Bugs Críticos Abertos",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 3, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM chamados WHERE type = 'BUG' AND priority = 'CRITICA' AND status != 'CONCLUIDO'",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Tempo Médio Resolução (h)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "h",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 48, "color": "yellow" }, { "value": 120, "color": "red" }] }
        }
      },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT ROUND(AVG(TIMESTAMPDIFF(HOUR, created_at, completed_at)), 1) AS value FROM chamados WHERE status = 'CONCLUIDO' AND completed_at IS NOT NULL",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Total Melhorias Pedidas",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT COUNT(*) AS value FROM chamados WHERE type = 'MELHORIA'",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Chamados Criados vs Concluídos por Dia",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "targets": [
        {
          "datasource": { "uid": "tradehub-mysql" },
          "rawSql": "SELECT DATE(created_at) AS time, COUNT(*) AS Criados FROM chamados WHERE created_at >= NOW() - INTERVAL 90 DAY GROUP BY DATE(created_at) ORDER BY time",
          "format": "time_series", "refId": "A"
        },
        {
          "datasource": { "uid": "tradehub-mysql" },
          "rawSql": "SELECT DATE(completed_at) AS time, COUNT(*) AS Concluídos FROM chamados WHERE completed_at >= NOW() - INTERVAL 90 DAY AND status = 'CONCLUIDO' GROUP BY DATE(completed_at) ORDER BY time",
          "format": "time_series", "refId": "B"
        }
      ]
    },

    {
      "id": 8,
      "type": "piechart",
      "title": "Por Prioridade",
      "gridPos": { "x": 14, "y": 4, "w": 5, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT priority AS metric, COUNT(*) AS value FROM chamados GROUP BY priority",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 9,
      "type": "piechart",
      "title": "Por Portal",
      "gridPos": { "x": 19, "y": 4, "w": 5, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT portal AS metric, COUNT(*) AS value FROM chamados GROUP BY portal ORDER BY value DESC",
        "format": "table", "refId": "A"
      }]
    },

    {
      "id": 10,
      "type": "table",
      "title": "Chamados Críticos em Aberto",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "uid": "tradehub-mysql" },
      "options": { "sortBy": [{ "displayName": "Criado", "desc": true }] },
      "targets": [{
        "datasource": { "uid": "tradehub-mysql" },
        "rawSql": "SELECT c.id AS ID, c.title AS Título, c.type AS Tipo, c.priority AS Prioridade, c.status AS Status, c.portal AS Portal, u.full_name AS 'Criado por', DATE_FORMAT(c.created_at, '%d/%m/%Y %H:%i') AS Criado FROM chamados c JOIN users u ON c.created_by_id = u.id WHERE c.status != 'CONCLUIDO' ORDER BY FIELD(c.priority,'CRITICA','ALTA','MEDIA','BAIXA'), c.created_at DESC LIMIT 30",
        "format": "table", "refId": "A"
      }]
    }

  ]
}
