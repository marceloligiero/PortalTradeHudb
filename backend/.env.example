# ══════════════════════════════════════════════════════
# backend/.env.example — variáveis do backend FastAPI
# Copiar para backend/.env:  cp backend/.env.example backend/.env
#
# Em Docker: usar hostname 'db' (nome do serviço docker-compose).
# Em desenvolvimento local: usar 'localhost'.
# ══════════════════════════════════════════════════════

# ── Base de dados ──────────────────────────────────────
# Docker:  mysql+pymysql://tradehub_user:<MYSQL_PASSWORD>@db:3306/tradehub_db
# Local:   mysql+pymysql://root:@localhost:3306/tradehub_db
#          sqlite:///./dev.db  (SQLite — sem MySQL instalado)
DATABASE_URL=mysql+pymysql://tradehub_user:mudar-em-producao@db:3306/tradehub_db

# ── Segurança JWT ──────────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=mudar-em-producao-gerar-chave-segura

# ── CORS ──────────────────────────────────────────────
# Docker prod:  http://localhost:80
# Docker dev:   http://localhost:5173,http://localhost:80
ALLOWED_ORIGINS=http://localhost:80,http://localhost:5173

# ── URL do frontend (para links nos emails) ────────────
FRONTEND_URL=http://localhost:80

# ── Modo debug (desactivar em produção) ────────────────
DEBUG=false

# ── Email (opcional — para recuperação de senha) ───────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
