# ════════════════════════════════════════════════════════════════════════════
# deploy/env.production.example — Template de produção sem Docker
#
# Como usar:
#   cp deploy/env.production.example backend/.env
#   nano backend/.env          # preencher os valores
#
# Gerar SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Gerar senha DB:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# ════════════════════════════════════════════════════════════════════════════

# ── Base de dados MySQL local ──────────────────────────────────────────────
# Sem Docker: host é sempre 'localhost', porta 3306
DATABASE_URL=mysql+pymysql://tradehub_user:SENHA_FORTE_AQUI@localhost:3306/tradehub_db

# ── Segurança JWT ──────────────────────────────────────────────────────────
# OBRIGATÓRIO: gerar uma chave única para cada instalação
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GERAR_CHAVE_UNICA_AQUI

# ── CORS — domínios autorizados ────────────────────────────────────────────
# Sem Docker: geralmente só o próprio hostname + localhost
# Separar por vírgula; sem espaços; sem barra final
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://portaltradedatahub

# ── URL pública do frontend (para links em emails) ─────────────────────────
FRONTEND_URL=http://portaltradedatahub

# ── Modo debug (SEMPRE false em produção) ─────────────────────────────────
DEBUG=false

# ── Email (SMTP para recuperação de senha) — opcional ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TLS=true

# ── SSO Microsoft (Entra ID) — opcional ───────────────────────────────────
# Deixar vazios para desactivar o botão "Entrar com Microsoft"
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://portaltradedatahub/api/auth/microsoft/callback
