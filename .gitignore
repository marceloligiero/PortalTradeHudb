# ══════════════════════════════════════════════════════
# .gitignore — Portal TradeHub
# Stack: Python 3.13 / FastAPI + React / TypeScript / Vite
# ══════════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
.venv/
venv/
backend/.venv/
backend/venv/
*.egg-info/
.eggs/
dist/
build/
*.whl

# ── Node.js / Frontend ─────────────────────────────────
frontend/node_modules/
frontend/.vite/
frontend/.cache/
frontend/dist/

# ── Ambiente (NUNCA commitar .env com valores reais) ───
.env
.env.local
.env.*.local
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.*.example
frontend/.env
frontend/.env.local
frontend/.env.production
# Manter apenas .env.example

# ── Logs e runtime ─────────────────────────────────────
*.log
logs/*.log
logs/*.log*
backend/audit.log

# ── Bases de dados de desenvolvimento ──────────────────
backend/*.db
*.sqlite
*.sqlite3

# ── Docker (volumes locais e imagens exportadas) ───────
# Os volumes Docker nomeados (tradehub_*) não ficam no repo
deploy-images/

# ── Testes e cobertura ─────────────────────────────────
backend/.pytest_cache/
backend/htmlcov/
.coverage
coverage.xml

# ── IDE ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig
*~

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Certificados SSL (nunca no repositório) ────────────
ssl/
*.pem
*.crt
*.key
*.p12
*.pfx

# ── Backups e temporários ──────────────────────────────
*.bak
*.backup
*.tmp
*.temp
*_backup*
*_dump*
*.dump.sql

# ── Ferramentas de tunnel (dev local) ──────────────────
cloudflared.exe
win-acme/
win-acme.zip
.cf-*.err
.cf-*.out
.lt-*.err
.lt-*.out

# ── Claude Code (IDE local) ────────────────────────────
.claude/

# ── Outros artefactos ──────────────────────────────────
backend/exception_trace.txt
backend/error_trace.txt
frontend/src/pages/admin/Reports_backup.tsx
install-service-output.txt

# ── Deploy keys (public key stored for reference, keep out of repo) ────────
.github/deploy-keys/
